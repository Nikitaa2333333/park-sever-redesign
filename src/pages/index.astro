  <!-- FOOTER -->
  <footer class="foot">
    <div class="wrap">
      <div class="foot__cols">
        <div>
          <div class="foot__brand">Парк Север</div>
          <p class="foot__about">Пространство на краю леса для тех, кто выбирает тишину. Приватный дом без потока людей и лишнего, на территории 12,4 га. Без соседей. Только природа, животные и ощущение, что никуда не нужно спешить.</p>
          <div class="socials">
            {site.socials.map((s: any) => <a href={s.href} target="_blank" rel="noopener noreferrer">{socialLabels[s.type] ?? s.type}</a>)}
          </div>
        </div>
        <div class="foot__col">
          <h4>Разделы</h4>
          {navMenu.map((m) => <a href={m.href}>{m.t}</a>)}
        </div>
        <div class="foot__col">
          <h4>Контакты</h4>
          <a href={c.phoneHref}>{c.phone}</a>
          <a href={c.emailHref}>{c.email}</a>
          <a href={c.whatsapp} target="_blank" rel="noopener noreferrer">WhatsApp</a>

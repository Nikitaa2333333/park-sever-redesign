          <p style="margin-top:16px;"><a class="tel" href={c.phoneHref} style="font-size:20px; font-weight:700;">{c.phone}</a></p>
          <div class="hero__cta" style="margin-top:24px; justify-content:flex-start;">
            <a class="btn btn--navy" href={booking}>Забронировать</a>
            <a class="btn btn--ghost btn--wa-outline" href={c.whatsapp} target="_blank" rel="noopener noreferrer">Написать в WhatsApp</a>
          </div>
        </div>
        <div class="cmap__right">
          <div class="map-frame">
            <iframe
              src="https://yandex.ru/map-widget/v1/org/park_sever/145451177721/?from=mapframe&ll=37.817199%2C56.459295&source=mapframe&utm_source=mapframe&z=15"
              title="Карта проезда к Парк Север"
              loading="lazy">
            </iframe>
          </div>
          <p class="contacts-addr">{c.address}</p>
        </div>
      </div>
    </div>

---
import SiteLayout from '../layouts/SiteLayout.astro';
import { getPage, site, reviews, withBase } from '../lib/content';
import vkNewsJson from '../../public/vk-news.json';

const page = getPage('home');
const byId: Record<string, any> = Object.fromEntries(page.sections.map((s: any) => [s.id, s]));

const blocksOf = (s: any, type: string) => (s?.blocks ?? []).filter((b: any) => b.type === type && !b.disabled);
const blockOf = (s: any, type: string) => blocksOf(s, type)[0];

// — hero / slider —
const slider = byId['slider'];
const heroVideos = (slider?.blocks ?? []).filter((b: any) => b.type === 'video');
const heroDesktop = heroVideos.find((v: any) => v.variant === 'desktop');
const heroMobile = heroVideos.find((v: any) => v.variant === 'mobile');
const heroAutumn = heroVideos.find((v: any) => v.variant === 'autumn-desktop');
const heroWinter = heroVideos.find((v: any) => v.variant === 'winter-desktop');

const heroEyebrow = blockOf(slider, 'subtitle')?.text; // "Отдых для двоих среди леса"
const heroTitle = blockOf(slider, 'heading')?.text; // "Парк Север"
const heroParas = (slider?.blocks ?? []).filter((b: any) => b.type === 'paragraph' && !b.disabled && b.variant !== 'accent' && !b.text.includes('Деятельность'));
const heroAccent = (slider?.blocks ?? []).find((b: any) => b.type === 'paragraph' && b.variant === 'accent')?.text; // курсивная строка hero (1.4)
const activityBadge = (slider?.blocks ?? []).find((b: any) => b.type === 'paragraph' && b.text.includes('Деятельность'))?.text;

// — oasis (new) —
const oasis = byId['oasis'];
const oasisTitle = blockOf(oasis, 'heading')?.text;
const oasisParas = blocksOf(oasis, 'paragraph').filter((b: any) => b.variant !== 'chips');
const oasisChips = blocksOf(oasis, 'paragraph').find((b: any) => b.variant === 'chips')?.text;
const oasisGallery = blockOf(oasis, 'gallery')?.images ?? [];

// — art-of-rest (new) —
const art = byId['art-of-rest'];
const artTitle = blockOf(art, 'heading')?.text;
const artSubtitle = blockOf(art, 'subtitle')?.text;
const artSteps = art?.items ?? [];

// — house-forest (new) —
const houseForest = byId['house-forest'];
const houseForestTitle = blockOf(houseForest, 'heading')?.text;
const houseForestParas = blocksOf(houseForest, 'paragraph');
const houseForestBtn = blockOf(houseForest, 'button');
const houseForestGallery = blockOf(houseForest, 'gallery')?.images ?? [];
// Слайды «Дома»: горизонтальные кадры — по одному на весь экран; вертикальные (портрет)
// идут коллажем по два в ряд, иначе на всю ширину их сильно растягивает/режет.
const houseVerticals = ['/images/home/accommodation/4.5.jpg', '/images/home/accommodation/4.6.jpg'];
const houseSlides: string[][] = [];
let housePendingV: string[] = [];
for (const src of houseForestGallery) {
  if (houseVerticals.includes(src)) {
    housePendingV.push(src);
    if (housePendingV.length === 2) { houseSlides.push(housePendingV); housePendingV = []; }
  } else {
    houseSlides.push([src]);
  }
}
if (housePendingV.length) houseSlides.push(housePendingV);

// — atmosphere (new) —
const atmosphere = byId['atmosphere'];
const atmosphereTitle = blockOf(atmosphere, 'heading')?.text;
const atmosphereSubtitle = blockOf(atmosphere, 'subtitle')?.text;
const atmosphereGallery = blockOf(atmosphere, 'gallery')?.images ?? [];
const atmosphereItems = atmosphere?.items ?? [];

// — our-world (new) —
const world = byId['our-world'];
const worldTitle = blockOf(world, 'heading')?.text;
const worldItems = world?.items ?? [];
// описания карточек «Наш мир» (инлайн — заказчик правит напрямую).
// Порядок соответствует items: Собаки · Олени · Пруд · Велопрогулки · Интересные места рядом.
const worldDesc: string[] = [
  'Золотистые ретриверы парка свободно гуляют по территории и всегда рады гостям.',
  'На территории — собственная ферма благородного оленя «Благородный Север».',
  'Тихий лесной пруд — для неспешных прогулок и созерцания.',
  'Скоростные велосипеды для прогулок по лесным маршрутам парка.',
  'Рядом — Сергиев Посад и другие места, куда стоит выбраться.',
];

// — advantages («Почему стоит выбрать нас») —
const advantages = byId['advantages'];
const advantagesItems = advantages?.items ?? [];

// — stories (ВК + отзывы Яндекс) —
const storiesSec = byId['reviews'];
const ot = (s: any) => blockOf(s, 'overtitle')?.text;
const hd = (s: any) => blockOf(s, 'heading')?.text;
const reviewItems = reviews?.items ?? [];
const vk = site.integrations.vkNews ?? {};
const yandexReviewsSrc = site.integrations.yandexReviews?.iframeSrc;

// — новости из ВК (build-time снапшот public/vk-news.json + seed-фолбэк) —
// Уровни фолбэка: живой JSON (перегенерируется в CI парсером) → seed-массив ниже
// (рендерится мгновенно без токена) → пустой блок-ссылка на группу. Сайт не ломается.
// ВАЖНО: seed — это НЕ выдуманные новости, а реальный пост из vk.com/park_sever,
// чтобы фолбэк был настоящим до подключения токена. После фетча его заменяет живая лента.
const VK_NEWS_SEED = [
  {
    id: 'seed_1',
    date: '15 июня 2026',
    title: 'Как рассказать про Парк Север?',
    text: 'Мы создавали это место таким, каким хотели видеть его для себя — чтобы утром открывать глаза и видеть лес.',
    image: '/images/main-menu/deers.jpg',
    link: vk.groupHref,
  },
  {
    id: 'seed_2',
    date: 'Июнь 2026',
    title: 'Утро в стеклянном доме',
    text: 'Туман над прудом, тишина и кофе у панорамного окна — так начинается день в парке.',
    image: '/images/home/oasis/1.1.jpg',
    link: vk.groupHref,
  },
  {
    id: 'seed_3',
    date: 'Июнь 2026',
    title: 'Наши олени',
    text: 'На территории — собственная ферма благородного оленя. Гости приходят понаблюдать за стадом и покормить его.',
    image: '/images/home/world/2.3.jpg',
    link: vk.groupHref,
  },
  {
    id: 'seed_4',
    date: 'Июнь 2026',
    title: 'Вечер у огня',
    text: 'Ужин на свежем воздухе и потрескивание костра — атмосфера для двоих, ради которой возвращаются.',
    image: '/images/home/atmosphere/5.1.jpg',
    link: vk.groupHref,
  },
];
const vkNews = (Array.isArray(vkNewsJson) && vkNewsJson.length ? vkNewsJson : VK_NEWS_SEED) as Array<{
  id: string; date: string; title: string; text: string; image: string; link: string;
}>;
// картинки ВК — абсолютные URL (отдаём как есть); локальные seed-пути — через withBase
const newsImg = (src: string) => (/^https?:\/\//.test(src) ? src : withBase(src));

const booking = site.contacts.bookingHref;
const c = site.contacts;

const socialLabels: Record<string, string> = {
  vk: 'ВКонтакте', whatsapp: 'WhatsApp', tiktok: 'TikTok',
  instagram: 'Instagram', telegram: 'Telegram', youtube: 'YouTube', rutube: 'RUTUBE',
};

const navMenu = [
  { t: 'Главная', href: '/' },
  { t: 'Дома', href: '/accommodation/house-1' },
  { t: 'Искусство отдыха', href: '#art-of-rest' },
  { t: 'Атмосфера для двоих', href: '#atmosphere' },
  { t: 'Наш мир', href: '#our-world' },
  { t: 'Истории', href: '#reviews' },
];
---
<SiteLayout title={page.seo.title}>
  <!-- NAV (Sticky Navigation with Mobile Hamburger) -->
  <nav class="nav">
    <div class="wrap">
      <a class="nav__logo" href="/">Парк Север</a>
      
      <button class="nav__toggle" aria-label="Открыть меню">
        <span></span>
        <span></span>
        <span></span>
      </button>

      <div class="nav__menu">
        {navMenu.map((m) => <a href={m.href}>{m.t}</a>)}
      </div>

      <a class="nav__book" href={booking}>Забронировать</a>
    </div>
  </nav>

  <!-- HERO (Seasonal video background, Overlay content) -->
  <header class="hero">
    <div class="hero__media">
      {heroDesktop && (
        <video id="video-summer" class="video-desktop" autoplay loop muted playsinline poster={withBase(heroDesktop.poster)}>
          <source src={withBase(heroDesktop.src)} type="video/mp4" />
        </video>
      )}
      {heroMobile && (
        <video id="video-summer-mob" class="video-mobile" autoplay loop muted playsinline poster={withBase(heroMobile.poster)}>
          <source src={withBase(heroMobile.src)} type="video/mp4" />
        </video>
      )}
      {heroAutumn && (
        <video id="video-autumn" class="video-desktop" loop muted playsinline poster={withBase(heroAutumn.poster)} style="display:none">
          <source src={withBase(heroAutumn.src)} type="video/mp4" />
        </video>
      )}
      {heroWinter && (
        <video id="video-winter" class="video-desktop" loop muted playsinline poster={withBase(heroWinter.poster)} style="display:none">
          <source src={withBase(heroWinter.src)} type="video/mp4" />
        </video>
      )}
    </div>
    <div class="hero__scrim"></div>
    <div class="wrap" style="text-align: left; max-width: 800px; margin-left: 0; padding-top: 140px; padding-bottom: 80px;">
      {heroEyebrow && <div class="hero__overline">{heroEyebrow.replace(/\s*\.\s*$/, '')}</div>}
      <h1 class="hero-title" style="color:#fff; margin:0;">{heroTitle}</h1>

      {heroAccent && <p class="hero-accent" style="margin:16px 0 28px;">{heroAccent}</p>}

      <div class="hero__lead-text" style="margin-bottom:28px; max-width:556px;">
        <p class="body-lead" style="color:#fff; font-weight:500; font-size:20px; line-height:1.4; margin:0;">{heroParas.map((p: any) => p.text).join(' ')}</p>
      </div>

      <!-- 1.5 Модуль бронирования znms (инлайновая форма заезд/выезд/гости).
           Скелетон показывается сразу и снимается, когда виджет отрисует свою форму. -->
      <div id="znms-widget-1" class="hero__booking">
        <div class="znms-skeleton" aria-hidden="true">
          <span class="znms-skeleton__title"></span>
          <div class="znms-skeleton__row">
            <span class="znms-skeleton__field"></span>
            <span class="znms-skeleton__field"></span>
          </div>
          <span class="znms-skeleton__field znms-skeleton__field--wide"></span>
          <span class="znms-skeleton__btn"></span>
        </div>
      </div>
    </div>
    {activityBadge && (
      <div style="position: absolute; bottom: 24px; left: 32px; font-size: 13px; font-family: var(--font-head); font-weight: 500; color: #fff; z-index: 2;">
        {activityBadge}
      </div>
    )}
  </header>

  <!-- Блок 2: Оазис спокойствия среди леса (тёмная сцена с зерном бумаги + карусель «фотокарточек») -->
  {oasis && !oasis.disabled && (
    <section class="sec sec--bark" id="oasis">
      <div class="wrap wrap--flush">
        <div class="oasis-head">
          <h2 class="h2" style="margin-bottom:24px;">{oasisTitle}</h2>
          {oasisParas.map((p: any) => (
            <p class="body" style="font-size:20px; line-height:1.4; font-weight:500; margin-bottom:16px;">{p.text}</p>
          ))}
          {oasisChips && (
            <p class="oasis-chips">{oasisChips}</p>
          )}
        </div>

        <div class="oasis-carousel" data-carousel>
          <div class="oasis-carousel__track">
            {oasisGallery.map((src: string) => (
              <figure class="oasis-card">
                <img src={withBase(src)} alt="Оазис спокойствия среди леса" loading="lazy" draggable="false" />
              </figure>
            ))}
          </div>
        </div>
      </div>
    </section>
  )}

  <!-- Блок 3: Искусство отдыха (Шаги-таймлайн) -->
  {art && !art.disabled && (
    <section class="sec sec--bark" id="art-of-rest">
      <div class="wrap wrap--flush">
        <div class="shead">
          <h2 class="h2">{artTitle}</h2>
          {artSubtitle && <p class="lead" style="margin-top:8px;">{artSubtitle}</p>}
        </div>
        <div class="art-steps">
          {artSteps.map((step: any) => (
            <div class="art-step">
              <div class="art-step__img">
                <img src={withBase(step.image)} alt={step.title} loading="lazy" />
                <div class="art-step__overlay">
                  <span class="art-step__num">{step.step}</span>
                  <h3 class="art-step__title">{step.title}</h3>
                  <p class="art-step__text">{step.text}</p>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Блок 4: Дом среди леса — полноэкранный фото-слайдер, текст поверх фото на коричневом градиенте -->
  {houseForest && !houseForest.disabled && (
    <section class="house" id="house-forest">
      <div class="slider-container house__slider">
        <div class="slider-snap">
          {houseSlides.map((group: string[]) => (
            <div class:list={["slider-snap__slide", { "slider-snap__slide--pair": group.length === 2 }]}>
              {group.map((src: string) => (
                <img src={withBase(src)} alt="Дом среди леса" loading="lazy" />
              ))}
            </div>
          ))}
        </div>
        <div class="house__scrim"></div>
        <div class="wrap wrap--flush house__content">
          <div class="house__text">
            <h2 class="h2 house__title">{houseForestTitle}</h2>
            {houseForestParas.map((p: any) => (
              <p class="lead house__lead">{p.text}</p>
            ))}
            {houseForestBtn && (
              <a class="btn btn--outline-light" href={houseForestBtn.href}>{houseForestBtn.text}</a>
            )}
          </div>
        </div>
        <div class="slider-arrows house__arrows">
          <button class="slider-arrow slider-arrow--left" aria-label="Назад">&larr;</button>
          <button class="slider-arrow slider-arrow--right" aria-label="Вперед">&rarr;</button>
        </div>
        <div class="slider-dots house__dots">
          {houseSlides.map((_, idx) => (
            <button class={`slider-dot ${idx === 0 ? 'active' : ''}`} data-index={idx} aria-label={`Слайд ${idx + 1}`}></button>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Блок 5: Атмосфера для двоих -->
  {atmosphere && !atmosphere.disabled && (
    <section class="sec sec--navy" id="atmosphere">
      <div class="wrap">
        <div class="shead" style="margin-bottom:48px;">
          <h2 class="h2">{atmosphereTitle}</h2>
          {atmosphereSubtitle && <p class="lead" style="color:#fff; text-align:center; margin-top:8px;">{atmosphereSubtitle}</p>}
        </div>

        <div class="atmosphere-icons atmosphere-icons--gold">
          {atmosphereItems.map((item: any) => (
            <div class="atmosphere-icon">
              <div class="atmosphere-icon__svg">
                {item.icon === 'heart' && (
                  <svg viewBox="0 -960 960 960" width="100%" height="100%" fill="currentColor">
                    <path d="m480-121-41-37q-106-97-175-167.5t-110-126Q113-507 96.5-552T80-643q0-90 60.5-150.5T290-854q57 0 105.5 27t84.5 78q42-54 89-79.5T670-854q89 0 149.5 60.5T880-643q0 46-16.5 91T806-451.5q-41 55.5-110 126T521-158l-41 37Z"/>
                  </svg>
                )}
                {item.icon === 'cake' && (
                  <svg viewBox="0 -960 960 960" width="100%" height="100%" fill="currentColor">
                    <path d="M160-80q-17 0-28.5-11.5T120-120v-219q0-24.75 17.63-42.38Q155.25-399 180-399h600q24.75 0 42.38 17.62Q840-363.75 840-339v219q0 17-11.5 28.5T800-80H160Zm47-379v-122q0-24.75 17.63-42.38Q242.25-641 267-641h183v-64q-20-14-30.5-30.53-10.5-16.54-10.5-39.88 0-14.59 5.5-28.09T430-827l50-53 50 53q10 10 16 23.5t6 28.09q0 23.34-11 39.88Q530-719 510-705v64h183q24.75 0 42.38 17.62Q753-605.75 753-581v122H207Z"/>
                  </svg>
                )}
                {item.icon === 'flower' && (
                  <svg viewBox="0 -960 960 960" width="100%" height="100%" fill="currentColor">
                    <path d="M480-570q34 0 57-24t23-56q0-34-23-57t-57-23q-32 0-56 23t-24 57q0 32 24 56t56 24Zm-65.5 168.5Q385-423 371-458q-6 0-12.5.5t-12.5.5q-48 0-82-34t-34-82q0-20 8-39.5t23-37.5q-14-18-22-37.5t-8-39.5q0-48 33.5-82t81.5-34q6 0 12.5.5t12.5.5q14-35 43.5-56.5T480-920q36 0 65.5 21.5T589-842q6 0 12.5-.5t12.5-.5q48 0 81.5 34t33.5 82q0 20-7.5 39.5T699-650q14 18 22 37.5t8 39.5q0 48-33.5 82T614-457q-6 0-12.5-.5T589-458q-14 35-43.5 56.5T480-380q-36 0-65.5-21.5ZM480-80q0-70 30-135t80-115q50-50 115-80t135-30q0 70-30 135t-80 115q-50 50-115 80T480-80Zm0 0q0-70-30-135t-80-115q-50-50-115-80t-135-30q0 70 30 135t80 115q50 50 115 80t135 30Z"/>
                  </svg>
                )}
                {item.icon === 'ring' && (
                  <svg viewBox="0 -960 960 960" width="100%" height="100%" fill="currentColor">
                    <path d="m358-625 105-215h34l105 215H358Zm97 475L101-575h354v425Zm50 0v-425h354L505-150Zm153-475L553-840h207l107 215H658Zm-565 0 107-215h207L302-625H93Z"/>
                  </svg>
                )}
                {item.icon === 'gift' && (
                  <svg viewBox="0 0 24 24" width="100%" height="100%" fill="currentColor">
                    <path d="M9.375 3a1.875 1.875 0 0 0 0 3.75h1.875v4.5H3.375A1.875 1.875 0 0 1 1.5 9.375v-.75c0-1.036.84-1.875 1.875-1.875h3.193A3.375 3.375 0 0 1 12 2.753a3.375 3.375 0 0 1 5.432 3.997h3.943c1.035 0 1.875.84 1.875 1.875v.75c0 1.036-.84 1.875-1.875 1.875H12.75v-4.5h1.875a1.875 1.875 0 1 0-1.875-1.875V6.75h-1.5V4.875C11.25 3.839 10.41 3 9.375 3ZM11.25 12.75H3v6.75a2.25 2.25 0 0 0 2.25 2.25h6v-9ZM12.75 12.75v9h6.75a2.25 2.25 0 0 0 2.25-2.25v-6.75h-9Z"/>
                  </svg>
                )}
              </div>
              <div class="atmosphere-icon__title">{item.title}</div>
            </div>
          ))}
        </div>
      </div>

      <div class="wrap wrap--flush">
        <div class="oasis-carousel oasis-carousel--sm" data-carousel>
          <div class="oasis-carousel__track">
            {atmosphereGallery.map((src: string) => (
              <figure class="oasis-card oasis-card--sm">
                <img src={withBase(src)} alt="Атмосфера для двоих" loading="lazy" draggable="false" />
              </figure>
            ))}
          </div>
        </div>
      </div>

      <div class="wrap">
        <div style="text-align: center; margin-top: 48px;">
          <a class="btn btn--outline-light" href="/special-offers">Узнать больше</a>
        </div>
      </div>
    </section>
  )}

  <!-- Блок 6: Наш мир -->
  {world && !world.disabled && (
    <section class="sec sec--green" id="our-world">
      <div class="wrap wrap--flush">
        <div class="shead" style="margin-bottom:32px;">
          <h2 class="h2">{worldTitle}</h2>
        </div>

        <div class="world-mosaic">
          {worldItems.map((item: any, i: number) => (
            <a class={`world-tile ${i < 2 ? 'world-tile--wide' : 'world-tile--med'}`} href={item.href}>
              <div class="world-tile__pic">
                <img src={withBase(item.image)} alt={item.title} loading="lazy" />
                <div class="world-tile__cap">
                  <div class="world-tile__title">{item.title}</div>
                  {worldDesc[i] && <p class="world-tile__desc">{worldDesc[i]}</p>}
                </div>
              </div>
            </a>
          ))}
        </div>
        
        <div style="text-align: center; margin-top: 48px;">
          <a class="btn btn--outline-light" href="/about">Исследовать наш мир</a>
        </div>
      </div>
    </section>
  )}

  <!-- Блок 7: Почему стоит выбрать нас -->
  {advantages && !advantages.disabled && (
    <section class="sec sec--green" id="advantages">
      <div class="wrap wrap--flush">
        <div class="shead" style="margin-bottom:40px;">
          <h2 class="h2">{hd(advantages)}</h2>
          {blockOf(advantages, 'subtitle')?.text && (
            <p class="lead" style="text-align:center; margin-top:8px;">{blockOf(advantages, 'subtitle').text}</p>
          )}
        </div>
        <div class="adv-grid">
          {advantagesItems.map((item: any) => (
            <div class="world-tile">
              <div class="world-tile__pic">
                <img src={withBase(item.image)} alt={item.text} loading="lazy" />
                <div class="world-tile__cap">
                  <p class="world-tile__desc">{item.text}</p>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Блок 8: Истории Парка (ВК + отзывы Яндекс) -->
  {storiesSec && !storiesSec.disabled && (
    <section class="sec section-calm" id="reviews">
      <div class="wrap">
        <div class="shead" style="margin-bottom:32px;">
          <h2 class="h2">{hd(storiesSec)}</h2>
        </div>
        <div class="stories-split">
          <!-- Слева: новости из ВК (build-time снапшот, см. scripts/fetch-vk-posts.js) -->
          <div class="stories-col">
            <h3 class="h3" style="margin-bottom:16px;">Наши истории</h3>
            {vkNews.length ? (
              <div class="news-feed">
                {vkNews.map((post) => (
                  <a class="news-card" href={post.link} target="_blank" rel="noopener noreferrer">
                    <div class="news-card__pic">
                      <img src={newsImg(post.image)} alt={post.title} loading="lazy" />
                    </div>
                    <div class="news-card__body">
                      <span class="news-card__date">{post.date}</span>
                      <h4 class="news-card__title">{post.title}</h4>
                      <p class="news-card__text">{post.text}</p>
                      <span class="news-card__more">Читать в ВКонтакте →</span>
                    </div>
                  </a>
                ))}
              </div>
            ) : (
              <a class="empty-note" href={vk.groupHref} target="_blank" rel="noopener noreferrer" style="display:block;">
                Лента ВКонтакте появится здесь. Открыть нашу группу →
              </a>
            )}
          </div>
          <!-- Справа: отзывы с Яндекс.Карт -->
          <div class="stories-col">
            <h3 class="h3" style="margin-bottom:16px;">Отзывы</h3>
            {yandexReviewsSrc ? (
              <div class="reviews-frame">
                <iframe src={yandexReviewsSrc} title="Отзывы о Парк Север на Яндекс.Картах" loading="lazy"></iframe>
              </div>
            ) : (
              <div class="empty-note">Скоро здесь появятся отзывы наших гостей.</div>
            )}
          </div>
        </div>
      </div>
    </section>
  )}

  <!-- Блок 8: Контакты + Карта -->
  <section class="sec section-calm" id="contacts">
    <div class="wrap wrap--flush">
      <div class="cmap">
        <div class="cbox">
          <h2 class="h2">Как добраться</h2>

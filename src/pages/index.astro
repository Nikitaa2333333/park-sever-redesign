      <div class="foot__cp">© {site.company} · {site.requisites.entity} · {site.requisites.note}</div>
    </div>
  </footer>

  <!-- КЛИЕНТСКИЕ СКРИПТЫ (Липкая шапка, Времена года, Слайдеры, Драг-эффект) -->
  <script is:inline>
    // 1. Мобильное меню
    const toggle = document.querySelector('.nav__toggle');
    const menu = document.querySelector('.nav__menu');
    if (toggle && menu) {
      toggle.addEventListener('click', () => {
        toggle.classList.toggle('active');
        menu.classList.toggle('open');
      });
      menu.querySelectorAll('a').forEach(l => {
        l.addEventListener('click', () => {
          toggle.classList.remove('active');
          menu.classList.remove('open');
        });
      });
    }

    // 1b. Открытие модуля бронирования znms без перезагрузки.
    // Все ссылки на ?znms_widget_open=... перехватываем и зовём open();
    // если виджет ещё не готов — браузер уходит по href (deep-link сработает на загрузке).
    document.querySelectorAll('a[href*="znms_widget_open"], [data-znms-open]').forEach(el => {
      el.addEventListener('click', (e) => {
        try {
          if (window.znmsWidget && window.znmsWidget.open && window.znmsWidget.open('#znms-widget-1')) {
            e.preventDefault();
          }
        } catch (err) { /* падаем на href */ }
      });
    });

    // 2. Сезонное видео
    (function() {
      const d = new Date();
      const m = d.getMonth() + 1; // 1-12
      const date = d.getDate();
      let season = 'summer';
      
      if ((m === 9 && date >= 1) || m === 10 || (m === 11 && date <= 14)) {
        season = 'autumn';
      } else if ((m === 11 && date >= 15) || m === 12 || m === 1 || m === 2) {
        season = 'winter';
      }
      
      const isMobile = window.innerWidth <= 640;
      
      const vSummer = document.getElementById('video-summer');
      const vSummerMob = document.getElementById('video-summer-mob');
      const vAutumn = document.getElementById('video-autumn');
      const vWinter = document.getElementById('video-winter');
      
      function playVideo(s) {
        // прячем все
        if (vSummer) vSummer.style.display = 'none';
        if (vSummerMob) vSummerMob.style.display = 'none';
        if (vAutumn) vAutumn.style.display = 'none';
        if (vWinter) vWinter.style.display = 'none';
        
        let active = null;
        if (isMobile) {
          active = vSummerMob; // моб по умолчанию
        } else {
          if (s === 'autumn') active = vAutumn || vSummer;
          else if (s === 'winter') active = vWinter || vSummer;
          else active = vSummer;
        }
        
        if (active) {
          active.style.display = 'block';
          active.play().catch(e => console.log('Autoplay blocked:', e));
        }
      }
      playVideo(season);
    })();

    // 3. Scroll-snap слайдеры (Оазис и Дом)
    document.querySelectorAll('.slider-container').forEach(container => {
      const track = container.querySelector('.slider-snap');
      const dots = container.querySelectorAll('.slider-dot');
      const leftArrow = container.querySelector('.slider-arrow--left');
      const rightArrow = container.querySelector('.slider-arrow--right');
      
      if (!track) return;
      
      track.addEventListener('scroll', () => {
        const width = track.offsetWidth;
        const index = Math.round(track.scrollLeft / width);
        dots.forEach((dot, idx) => {
          if (idx === index) dot.classList.add('active');
          else dot.classList.remove('active');
        });
      });
      
      if (leftArrow) {
        leftArrow.addEventListener('click', () => {
          track.scrollBy({ left: -track.offsetWidth, behavior: 'smooth' });
        });
      }
      if (rightArrow) {
        rightArrow.addEventListener('click', () => {
          track.scrollBy({ left: track.offsetWidth, behavior: 'smooth' });
        });
      }
      
      dots.forEach((dot, idx) => {
        dot.addEventListener('click', () => {
          track.scrollTo({ left: idx * track.offsetWidth, behavior: 'smooth' });
        });
      });
    });

    // 4. Драг-слайдер для Атмосферы
    document.querySelectorAll('.slider-drag').forEach(slider => {
      let isDown = false;
      let startX;
      let scrollLeft;
      
      slider.addEventListener('mousedown', (e) => {
        isDown = true;
        slider.classList.add('active');
        startX = e.pageX - slider.offsetLeft;
        scrollLeft = slider.scrollLeft;
      });
      slider.addEventListener('mouseleave', () => {
        isDown = false;
        slider.classList.remove('active');
      });
      slider.addEventListener('mouseup', () => {
        isDown = false;
        slider.classList.remove('active');
      });
      slider.addEventListener('mousemove', (e) => {
        if (!isDown) return;
        e.preventDefault();
        const x = e.pageX - slider.offsetLeft;
        const walk = (x - startX) * 2;
        slider.scrollLeft = scrollLeft - walk;
      });
    });

    // 5. Карусель «Оазиса» — горизонтальный скролл + перетаскивание мышью
    //    (снап по карточкам — CSS; на тач свайп работает нативно)
    document.querySelectorAll('[data-carousel]').forEach(carousel => {
      const track = carousel.querySelector('.oasis-carousel__track');
      if (!track) return;

      let isDown = false, startX = 0, startScroll = 0, moved = false;
      track.addEventListener('mousedown', (e) => {
        isDown = true; moved = false;
        startX = e.pageX; startScroll = track.scrollLeft;
        track.classList.add('dragging');
      });
      const endDrag = () => {
        if (!isDown) return;
        isDown = false;
        track.classList.remove('dragging');
      };
      track.addEventListener('mouseleave', endDrag);
      window.addEventListener('mouseup', endDrag);
      track.addEventListener('mousemove', (e) => {
        if (!isDown) return;
        const walk = e.pageX - startX;
        if (Math.abs(walk) > 4) moved = true;
        track.scrollLeft = startScroll - walk;
      });
      // не «кликать» по карточке после перетаскивания
      track.addEventListener('click', (e) => { if (moved) { e.preventDefault(); } }, true);
    });
  </script>

  <!-- Автосмена слайдов блока «Дом среди леса» (без стрелок) -->
  <script is:inline>
    (function () {
      const track = document.querySelector('.house__slider .slider-snap');
      if (!track) return;
      const slides = track.querySelectorAll('.slider-snap__slide');
      if (slides.length < 2) return;
      let i = 0;
      setInterval(function () {
        i = (i + 1) % slides.length;
        track.scrollTo({ left: i * track.offsetWidth, behavior: 'smooth' });
      }, 5000);
    })();
  </script>

</SiteLayout>

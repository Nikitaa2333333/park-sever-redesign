---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { site } from '../lib/content';
import '../styles/preview.css';
const { title } = Astro.props;
const booking = site.integrations.booking;
const initJs = `window.addEventListener('load',function(){try{window.znmsWidget&&window.znmsWidget.init(${JSON.stringify(booking.container)},${JSON.stringify(booking.initConfig)})}catch(e){console.warn('znms widget:',e)}});`;
---
<!doctype html>
<html lang="ru">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
  </head>
  <body>
    <Header />
    <main><slot /></main>
    <Footer />
    <script src={booking.scriptSrc} is:inline></script>
    <script is:inline set:html={initJs}></script>
  </body>
</html>
